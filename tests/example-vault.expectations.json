{
  "_schema": {
    "description": "Per-document expected validator output for examples/example/. Each key is a vault-relative path; the value declares the doc's expected `valid` boolean plus the field-codes of the diagnostics it should produce. The test (tests/example-vault.test.js) runs `cli/validate-documents.js --root examples/example --json` once and asserts each result matches its entry here. Adding a new fixture doc = adding a new entry. No test code changes.",
    "entryShape": {
      "valid": "boolean — must match result.valid exactly",
      "errors": "array of error-field codes — every code must appear in result.errors[*].field; result.errors.length must equal this list's length",
      "warnings": "array of warning-field codes — every code must appear in result.warnings[*].field; result.warnings.length must equal this list's length"
    }
  },

